(load "Test.carp")
(load "../web.carp")
(use Test)

; Build a masked client frame for testing decode-frame.
; Opcode 1 (text), mask key [0x37 0xfa 0x21 0x3d].
(defn make-masked-text-frame [msg]
  (let-do [bytes (String.to-bytes msg)
           len (Array.length &bytes)
           frame (the (Array Byte) [])
           mask [(Byte.from-int 55) (Byte.from-int 250)
                 (Byte.from-int 33) (Byte.from-int 61)]]
    ; FIN + text
    (Array.push-back! &frame (Byte.from-int 129))
    ; MASK bit + length (assume < 126)
    (Array.push-back! &frame (Byte.from-int (+ 128 len)))
    ; Mask key
    (for [i 0 4]
      (Array.push-back! &frame @(Array.unsafe-nth &mask i)))
    ; Masked payload
    (for [i 0 len]
      (Array.push-back! &frame
        (Byte.from-int (bit-xor (Byte.to-int @(Array.unsafe-nth &bytes i))
                                (Byte.to-int @(Array.unsafe-nth &mask (Int.mod i 4)))))))
    frame))

(deftest test
  ; ---------------------------------------------------------------------------
  ; Base64 encoding
  ; ---------------------------------------------------------------------------

  (assert-equal test
    ""
    &(Base64.encode &(String.to-bytes &@""))
    "Base64 empty")

  (assert-equal test
    "Zg=="
    &(Base64.encode &(String.to-bytes &@"f"))
    "Base64 single byte")

  (assert-equal test
    "Zm8="
    &(Base64.encode &(String.to-bytes &@"fo"))
    "Base64 two bytes")

  (assert-equal test
    "Zm9v"
    &(Base64.encode &(String.to-bytes &@"foo"))
    "Base64 three bytes")

  (assert-equal test
    "Zm9vYmFy"
    &(Base64.encode &(String.to-bytes &@"foobar"))
    "Base64 six bytes")

  ; ---------------------------------------------------------------------------
  ; SHA-1 + Base64
  ; ---------------------------------------------------------------------------

  (assert-equal test
    "qZk+NkcGgWq6PiVxeFDCbJzQ2J0="
    &(Base64.encode &(SHA1.digest &(String.to-bytes &@"abc")))
    "SHA1 of 'abc'")

  (assert-equal test
    "2jmj7l5rSw0yVb/vlWAYkK/YBwk="
    &(Base64.encode &(SHA1.digest &(String.to-bytes &@"")))
    "SHA1 of empty string")

  ; ---------------------------------------------------------------------------
  ; WebSocket accept key (RFC 6455 section 4.2.2 example)
  ; ---------------------------------------------------------------------------

  (assert-equal test
    "s3pPLMBiTxaQ9kYGzzhZRbK+xOo="
    &(ws-accept-key "dGhlIHNhbXBsZSBub25jZQ==")
    "accept key matches RFC 6455 example")

  ; ---------------------------------------------------------------------------
  ; Frame encoding (server-to-client, no mask)
  ; ---------------------------------------------------------------------------

  (assert-equal test
    2
    (let [f (WebSocket.encode-text "")]
      (Array.length &f))
    "encode-text empty is 2 bytes (header only)")

  (assert-equal test
    (Byte.from-int 129) ; 0x81 = FIN + text
    (let [f (WebSocket.encode-text "hi")]
      @(Array.unsafe-nth &f 0))
    "encode-text sets FIN + opcode 1")

  (assert-equal test
    (Byte.from-int 2)
    (let [f (WebSocket.encode-text "hi")]
      @(Array.unsafe-nth &f 1))
    "encode-text sets payload length")

  (assert-equal test
    "hi"
    &(let-do [f (WebSocket.encode-text "hi")
              payload (the (Array Byte) [])]
       (for [i 2 (Array.length &f)]
         (Array.push-back! &payload @(Array.unsafe-nth &f i)))
       (String.from-bytes &payload))
    "encode-text payload matches input")

  ; ---------------------------------------------------------------------------
  ; Frame decoding (client-to-server, masked)
  ; ---------------------------------------------------------------------------

  (assert-true test
    (Maybe.just? &(WebSocket.decode-frame &(make-masked-text-frame "hello") 0))
    "decode-frame succeeds on complete frame")

  (assert-equal test
    1
    (match (WebSocket.decode-frame &(make-masked-text-frame "hello") 0)
      (Maybe.Just f) @(WSFrame.opcode &f)
      (Maybe.Nothing) -1)
    "decode-frame returns opcode 1 for text")

  (assert-equal test
    "hello"
    &(match (WebSocket.decode-frame &(make-masked-text-frame "hello") 0)
       (Maybe.Just f) (String.from-bytes (WSFrame.payload &f))
       (Maybe.Nothing) @"FAIL")
    "decode-frame unmasks payload correctly")

  (assert-equal test
    11  ; 2 header + 4 mask + 5 payload
    (match (WebSocket.decode-frame &(make-masked-text-frame "hello") 0)
      (Maybe.Just f) @(WSFrame.consumed &f)
      (Maybe.Nothing) -1)
    "decode-frame reports correct consumed bytes")

  (assert-true test
    (Maybe.nothing? &(WebSocket.decode-frame &(the (Array Byte) [(Byte.from-int 129)]) 0))
    "decode-frame returns Nothing for incomplete buffer")

  ; ---------------------------------------------------------------------------
  ; Encode/decode round-trip (encode server frame, decode without mask)
  ; ---------------------------------------------------------------------------

  (assert-equal test
    "round-trip"
    &(let [encoded (WebSocket.encode-text "round-trip")]
       (match (WebSocket.decode-frame &encoded 0)
         (Maybe.Just f) (String.from-bytes (WSFrame.payload &f))
         (Maybe.Nothing) @"FAIL"))
    "server frame round-trips through decode")

  ; ---------------------------------------------------------------------------
  ; Extended length encoding (16-bit)
  ; ---------------------------------------------------------------------------

  (assert-equal test
    (Byte.from-int 126)
    (let [f (WebSocket.encode-text &(String.allocate 200 \x))]
      @(Array.unsafe-nth &f 1))
    "encode-text uses 16-bit length for >125 bytes")

  (assert-equal test
    200
    (let [f (WebSocket.encode-text &(String.allocate 200 \x))]
      (- (Array.length &f) 4))
    "encode-text 16-bit payload length correct")

  ; ---------------------------------------------------------------------------
  ; Decode at non-zero offset (multiple frames in buffer)
  ; ---------------------------------------------------------------------------

  (assert-equal test
    "world"
    &(let-do [f1 (make-masked-text-frame "hello")
              f2 (make-masked-text-frame "world")
              buf (the (Array Byte) [])]
       (for [i 0 (Array.length &f1)]
         (Array.push-back! &buf @(Array.unsafe-nth &f1 i)))
       (for [i 0 (Array.length &f2)]
         (Array.push-back! &buf @(Array.unsafe-nth &f2 i)))
       (let [off (Array.length &f1)]
         (match (WebSocket.decode-frame &buf off)
           (Maybe.Just f) (String.from-bytes (WSFrame.payload &f))
           (Maybe.Nothing) @"FAIL")))
    "decode-frame at non-zero offset")

  ; ---------------------------------------------------------------------------
  ; Close and pong frame codec
  ; ---------------------------------------------------------------------------

  (assert-equal test
    8
    (let [f (WebSocket.encode-close)]
      (match (WebSocket.decode-frame &f 0)
        (Maybe.Just frame) @(WSFrame.opcode &frame)
        (Maybe.Nothing) -1))
    "decode close frame opcode")

  (assert-equal test
    10
    (let [f (WebSocket.encode-pong &(String.to-bytes &@"ping"))]
      (match (WebSocket.decode-frame &f 0)
        (Maybe.Just frame) @(WSFrame.opcode &frame)
        (Maybe.Nothing) -1))
    "decode pong frame opcode")

  ; ---------------------------------------------------------------------------
  ; web-routable-path
  ; ---------------------------------------------------------------------------

  (assert-equal test
    "/"
    &(let [req (Result.unsafe-from-success
                 (Request.parse "GET / HTTP/1.1\r\nHost: x\r\n\r\n"))]
       (web-routable-path &req))
    "routable-path for root")

  (assert-equal test
    "/users/42"
    &(let [req (Result.unsafe-from-success
                 (Request.parse "GET /users/42 HTTP/1.1\r\nHost: x\r\n\r\n"))]
       (web-routable-path &req))
    "routable-path with segments")

  ; ---------------------------------------------------------------------------
  ; Keep-alive detection
  ; ---------------------------------------------------------------------------

  (assert-true test
    (let [req (Result.unsafe-from-success
                (Request.parse "GET / HTTP/1.1\r\nHost: x\r\n\r\n"))]
      (web-keep-alive? &req))
    "HTTP/1.1 defaults to keep-alive")

  (assert-false test
    (let [req (Result.unsafe-from-success
                (Request.parse "GET / HTTP/1.1\r\nHost: x\r\nConnection: close\r\n\r\n"))]
      (web-keep-alive? &req))
    "Connection: close disables keep-alive")

  ; ---------------------------------------------------------------------------
  ; Upgrade detection
  ; ---------------------------------------------------------------------------

  (assert-true test
    (let [app (App.WS (App.create) @"/ws" (fn [e p w] ()))
          buf (String.to-bytes &@"GET /ws HTTP/1.1\r\nHost: x\r\nUpgrade: websocket\r\nSec-WebSocket-Key: dGhlIHNhbXBsZSBub25jZQ==\r\n\r\n")]
      (Maybe.just? &(web-try-ws-upgrade &buf (App.ws-routes &app))))
    "upgrade detection matches WS route")

  (assert-true test
    (let [app (App.create)
          buf (String.to-bytes &@"GET /ws HTTP/1.1\r\nHost: x\r\nUpgrade: websocket\r\nSec-WebSocket-Key: abc\r\n\r\n")]
      (Maybe.nothing? &(web-try-ws-upgrade &buf (App.ws-routes &app))))
    "upgrade detection with no WS routes")

  (assert-true test
    (let [app (App.WS (App.create) @"/ws" (fn [e p w] ()))
          buf (String.to-bytes &@"GET / HTTP/1.1\r\nHost: x\r\n\r\n")]
      (Maybe.nothing? &(web-try-ws-upgrade &buf (App.ws-routes &app))))
    "non-upgrade request returns Nothing")

  ; ---------------------------------------------------------------------------
  ; App construction with WS routes
  ; ---------------------------------------------------------------------------

  (assert-equal test
    1
    (let [app (-> (App.create)
                  (App.WS @"/ws/echo"
                    (fn [event params ws] ())))]
      (Array.length (App.ws-routes &app)))
    "App.WS adds a WS route")

  (assert-equal test
    1
    (let [app (-> (App.create)
                  (App.GET @"/" (fn [r p] (Response.text @"")))
                  (App.WS @"/ws/echo" (fn [e p w] ())))]
      (Array.length (App.routes &app)))
    "WS routes do not affect HTTP routes count")
)
