(doc Web "is a minimal web framework for Carp with WebSocket support.

## Installation

```
(load \"git@github.com:carpentry-org/web@0.4.0\")
```

## Usage

```
(load \"git@github.com:carpentry-org/web@0.4.0\")

(defn hello [req params]
  (Response.text @\"Hello, world!\"))

(defn echo [event params ws]
  (match-ref event
    (WSEvent.Connect) (WebSocket.send ws @\"connected\")
    (WSEvent.Message msg) (WebSocket.send ws (fmt \"echo: %s\" msg))
    (WSEvent.Close) ()))

(defserver \"0.0.0.0\" 8080
  (GET \"/hello\" hello)
  (WS  \"/ws/echo\" echo))
```")

; ---------------------------------------------------------------------------
; Dependencies
; ---------------------------------------------------------------------------

(load "git@github.com:carpentry-org/http@0.1.4")
(load "git@github.com:carpentry-org/socket@0.1.4")
(load "git@github.com:carpentry-org/json@0.2.2")
(load "git@github.com:carpentry-org/file@0.1.2")
(load "git@github.com:carpentry-org/log@0.1.1")

; ---------------------------------------------------------------------------
; SHA-1 (RFC 3174) — used for WebSocket handshake tokens
; ---------------------------------------------------------------------------

(defmodule SHA1
  (hidden mask32)
  (defn mask32 [x] (bit-and x 4294967295l))

  (hidden rotl32)
  (defn rotl32 [x n]
    (let [m (mask32 x)]
      (mask32 (bit-or (bit-shift-left m n)
                      (bit-shift-right m (- 32l n))))))

  (hidden word32)
  (defn word32 [b0 b1 b2 b3]
    (mask32 (bit-or (bit-or (bit-shift-left (Long.from-int b0) 24l)
                            (bit-shift-left (Long.from-int b1) 16l))
                    (bit-or (bit-shift-left (Long.from-int b2) 8l)
                            (Long.from-int b3)))))

  (doc digest "computes the SHA-1 digest of a byte array, returning 20 bytes.")
  (defn digest [data]
    (let-do [msg-len (Array.length data)
             bit-len (* (Long.from-int msg-len) 8l)
             pad-len (let [r (Int.mod (+ msg-len 9) 64)]
                       (+ (+ msg-len 9) (if (= r 0) 0 (- 64 r))))
             buf (Array.replicate pad-len &(Byte.from-int 0))]
      (for [i 0 msg-len]
        (Array.aset! &buf i @(Array.unsafe-nth data i)))
      (Array.aset! &buf msg-len (Byte.from-int 128))
      (for [i 0 8]
        (Array.aset! &buf (+ (- pad-len 8) i)
          (Byte.from-int (Long.to-int
            (bit-and (bit-shift-right bit-len (* (Long.from-int (- 7 i)) 8l)) 255l)))))
      (let-do [h0 1732584193l
               h1 4023233417l
               h2 2562383102l
               h3 271733878l
               h4 3285377520l]
        (for [blk 0 (/ pad-len 64)]
          (let-do [off (* blk 64)
                   w (Array.replicate 80 &0l)]
            (for [j 0 16]
              (let [bi (+ off (* j 4))]
                (Array.aset! &w j
                  (word32 (Byte.to-int @(Array.unsafe-nth &buf bi))
                          (Byte.to-int @(Array.unsafe-nth &buf (+ bi 1)))
                          (Byte.to-int @(Array.unsafe-nth &buf (+ bi 2)))
                          (Byte.to-int @(Array.unsafe-nth &buf (+ bi 3)))))))
            (for [j 16 80]
              (Array.aset! &w j
                (rotl32 (bit-xor (bit-xor @(Array.unsafe-nth &w (- j 3))
                                          @(Array.unsafe-nth &w (- j 8)))
                                 (bit-xor @(Array.unsafe-nth &w (- j 14))
                                          @(Array.unsafe-nth &w (- j 16))))
                        1l)))
            (let-do [a h0 b h1 c h2 d h3 e h4]
              (for [j 0 80]
                (let [f (cond
                          (< j 20) (mask32 (bit-or (bit-and b c)
                                                   (bit-and (mask32 (bit-not b)) d)))
                          (< j 40) (mask32 (bit-xor b (bit-xor c d)))
                          (< j 60) (mask32 (bit-or (bit-or (bit-and b c) (bit-and b d))
                                                   (bit-and c d)))
                          (mask32 (bit-xor b (bit-xor c d))))
                      k (cond
                          (< j 20) 1518500249l
                          (< j 40) 1859775393l
                          (< j 60) 2400959708l
                          3395469782l)
                      temp (mask32 (+ (+ (+ (+ (rotl32 a 5l) f) e) k)
                                     @(Array.unsafe-nth &w j)))]
                  (do (set! e d) (set! d c)
                      (set! c (rotl32 b 30l))
                      (set! b a) (set! a temp))))
              (set! h0 (mask32 (+ h0 a)))
              (set! h1 (mask32 (+ h1 b)))
              (set! h2 (mask32 (+ h2 c)))
              (set! h3 (mask32 (+ h3 d)))
              (set! h4 (mask32 (+ h4 e))))))
        (let-do [result (Array.replicate 20 &(Byte.from-int 0))]
          (for [i 0 5]
            (let [h (cond (= i 0) h0 (= i 1) h1 (= i 2) h2 (= i 3) h3 h4)
                  base (* i 4)]
              (for [j 0 4]
                (Array.aset! &result (+ base j)
                  (Byte.from-int (Long.to-int
                    (bit-and (bit-shift-right h (* (Long.from-int (- 3 j)) 8l)) 255l)))))))
          result))))
)

; ---------------------------------------------------------------------------
; Base64 encoding (RFC 4648)
; ---------------------------------------------------------------------------

(defmodule Base64
  (hidden b64-alphabet)
  (def b64-alphabet @"ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/")

  (doc encode "base64-encodes a byte array.")
  (defn encode [data]
    (let-do [len (Array.length data)
             out (the (Array Char) [])
             i 0]
      (while (<= (+ i 3) len)
        (let [b0 (Byte.to-int @(Array.unsafe-nth data i))
              b1 (Byte.to-int @(Array.unsafe-nth data (+ i 1)))
              b2 (Byte.to-int @(Array.unsafe-nth data (+ i 2)))]
          (do (Array.push-back! &out (String.char-at &b64-alphabet (bit-shift-right b0 2)))
              (Array.push-back! &out (String.char-at &b64-alphabet
                (bit-or (bit-shift-left (bit-and b0 3) 4) (bit-shift-right b1 4))))
              (Array.push-back! &out (String.char-at &b64-alphabet
                (bit-or (bit-shift-left (bit-and b1 15) 2) (bit-shift-right b2 6))))
              (Array.push-back! &out (String.char-at &b64-alphabet (bit-and b2 63)))
              (set! i (+ i 3)))))
      (let [rem (- len i)]
        (cond
          (= rem 1)
            (let [b0 (Byte.to-int @(Array.unsafe-nth data i))]
              (do (Array.push-back! &out (String.char-at &b64-alphabet (bit-shift-right b0 2)))
                  (Array.push-back! &out (String.char-at &b64-alphabet
                    (bit-shift-left (bit-and b0 3) 4)))
                  (Array.push-back! &out \=)
                  (Array.push-back! &out \=)))
          (= rem 2)
            (let [b0 (Byte.to-int @(Array.unsafe-nth data i))
                  b1 (Byte.to-int @(Array.unsafe-nth data (+ i 1)))]
              (do (Array.push-back! &out (String.char-at &b64-alphabet (bit-shift-right b0 2)))
                  (Array.push-back! &out (String.char-at &b64-alphabet
                    (bit-or (bit-shift-left (bit-and b0 3) 4) (bit-shift-right b1 4))))
                  (Array.push-back! &out (String.char-at &b64-alphabet
                    (bit-shift-left (bit-and b1 15) 2)))
                  (Array.push-back! &out \=)))
          ()))
      (String.from-chars &out)))
)

; ---------------------------------------------------------------------------
; Map extensions: mutable value access for event loops
; ---------------------------------------------------------------------------

(defmodule Map
  (doc update-value! "calls `f` with a reference to the value at key `k`.
Does nothing if the key is not found. The reference allows mutation through
FFI functions (e.g. reading into a stream's buffer).")
  (defn update-value! [m k f]
    (let [idx (Int.positive-mod (hash k) @(n-buckets m))]
      (let [bucket (Array.unsafe-nth (buckets m) idx)
            i (Bucket.find bucket k)]
        (when (>= i 0)
          (~f (Pair.b (Array.unsafe-nth (Bucket.entries bucket) i)))))))

  (doc value-ref! "calls `f` with a reference to the value at key `k` and
returns whatever `f` returns. If the key is missing, returns `default`.")
  (defn value-ref! [m k f default]
    (let [idx (Int.positive-mod (hash k) @(n-buckets m))]
      (let [bucket (Array.unsafe-nth (buckets m) idx)
            i (Bucket.find bucket k)]
        (if (>= i 0)
          (~f (Pair.b (Array.unsafe-nth (Bucket.entries bucket) i)))
          default))))

)

; ---------------------------------------------------------------------------
; Response helpers
; ---------------------------------------------------------------------------

(defmodule Response
  (doc text "creates a 200 OK response with a plain text body.")
  (defn text [body]
    (let [k @"Content-Type"
          v [@"text/plain; charset=utf-8"]]
      (init 200 @"OK" @"HTTP/1.1" [] (Map.put {} &k &v) body)))

  (doc html "creates a 200 OK response with an HTML body.")
  (defn html [body]
    (let [k @"Content-Type"
          v [@"text/html; charset=utf-8"]]
      (init 200 @"OK" @"HTTP/1.1" [] (Map.put {} &k &v) body)))

  (doc json "creates a 200 OK response with a JSON body.")
  (defn json [j]
    (let [k @"Content-Type"
          v [@"application/json"]
          body (match (JSON.str j)
                 (Result.Success s) s
                 (Result.Error _) @"{}")]
      (init 200 @"OK" @"HTTP/1.1" [] (Map.put {} &k &v) body)))

  (doc not-found "creates a 404 Not Found response.")
  (defn not-found []
    (init 404 @"Not Found" @"HTTP/1.1" [] {} @"Not Found"))

  (doc bad-request "creates a 400 Bad Request response.")
  (defn bad-request []
    (init 400 @"Bad Request" @"HTTP/1.1" [] {} @"Bad Request"))

  (doc redirect "creates a 302 redirect response to `url`.")
  (defn redirect [url]
    (let [k @"Location"
          v [url]]
      (init 302 @"Found" @"HTTP/1.1" [] (Map.put {} &k &v) @"")))

  (doc with-header "adds a header to a response.")
  (defn with-header [r k v]
    (set-headers r
      (Map.update-with-default
        @(headers &r) &k &(fn [a] (Array.push-back a @&v)) [])))

  (doc with-status "sets the status code and message of a response.")
  (defn with-status [r code msg]
    (set-message (set-code r code) msg))

  (doc content-type-for "infers an HTTP `Content-Type` for a file path
based on its extension. Unknown extensions return `application/octet-stream`.")
  (defn content-type-for [path]
    (cond
      (String.ends-with? path ".html")  @"text/html; charset=utf-8"
      (String.ends-with? path ".js")    @"application/javascript; charset=utf-8"
      (String.ends-with? path ".mjs")   @"application/javascript; charset=utf-8"
      (String.ends-with? path ".css")   @"text/css; charset=utf-8"
      (String.ends-with? path ".svg")   @"image/svg+xml"
      (String.ends-with? path ".json")  @"application/json"
      (String.ends-with? path ".png")   @"image/png"
      (String.ends-with? path ".jpg")   @"image/jpeg"
      (String.ends-with? path ".jpeg")  @"image/jpeg"
      (String.ends-with? path ".gif")   @"image/gif"
      (String.ends-with? path ".ico")   @"image/x-icon"
      (String.ends-with? path ".webp")  @"image/webp"
      (String.ends-with? path ".woff")  @"font/woff"
      (String.ends-with? path ".woff2") @"font/woff2"
      (String.ends-with? path ".txt")   @"text/plain; charset=utf-8"
      (String.ends-with? path ".xml")   @"application/xml"
      (String.ends-with? path ".pdf")   @"application/pdf"
      @"application/octet-stream"))

  (doc file "creates a 200 OK response by reading `path` from disk. Returns
a 404 Not Found response if the file is missing or unreadable. The
`Content-Type` header is inferred from the file extension via
[`content-type-for`](#content-type-for).")
  (defn file [path]
    (match (File.open-with path "r")
      (Result.Error _) (not-found)
      (Result.Success f)
        (match (File.read-all &f)
          (Result.Error _) (do (File.close f) (not-found))
          (Result.Success contents)
            (let [k @"Content-Type"
                  v [(content-type-for path)]]
              (do (File.close f)
                  (init 200 @"OK" @"HTTP/1.1" [] (Map.put {} &k &v) contents))))))

  (doc chunked "creates a response with `Transfer-Encoding: chunked`.

The body is built from an array of chunk strings, each encoded with the
chunked framing (`<hex-length>\\r\\n<data>\\r\\n`) and terminated by a
final `0\\r\\n\\r\\n`.

```
(Response.chunked 200 @\"text/plain\"
  &[@\"first chunk\" @\"second chunk\"])
```

The chunks are pre-encoded into a single buffer. For truly lazy streaming
where chunks are generated on demand, a future version will provide a
callback-based API.")
  (defn chunked [code content-type chunks]
    (let-do [buf @""]
      (for [i 0 (Array.length chunks)]
        (let [chunk (Array.unsafe-nth chunks i)
              len (String.length chunk)]
          (do (set! buf (String.append &buf &(fmt "%x\r\n" len)))
              (set! buf (String.append &buf chunk))
              (set! buf (String.append &buf "\r\n")))))
      (set! buf (String.append &buf "0\r\n\r\n"))
      (-> (init code @"OK" @"HTTP/1.1" [] {} buf)
          (with-header @"Transfer-Encoding" @"chunked")
          (with-header @"Content-Type" content-type))))

  (doc sendfile "creates a 200 OK response that signals the server to
transfer the file at `path` directly to the socket via `sendfile(2)`,
avoiding the user-space copy. Falls back to [`file`](#file) if the
server does not detect the `X-Sendfile` header.

The `Content-Type` is inferred from the extension. The server sets
`Content-Length` from the file size.")
  (defn sendfile [path]
    (-> (init 200 @"OK" @"HTTP/1.1" [] {} @"")
        (with-header @"Content-Type" (content-type-for path))
        (with-header @"X-Sendfile" @path)))
)

; ---------------------------------------------------------------------------
; Form parsing
; ---------------------------------------------------------------------------

(doc Form "provides helpers for parsing `application/x-www-form-urlencoded`
request bodies.")
(defmodule Form
  (doc parse "parses a URL-encoded form body into a `(Map String String)`.

```
(let [data (Form.decode (Request.body req))]
  (Map.get &data \"username\"))
```

Keys and values are URL-decoded. Duplicate keys keep the last value.")
  (hidden decode-form-value)
  (defn decode-form-value [s]
    (let-do [cs (String.to-bytes s)
             len (Array.length &cs)]
      (for [i 0 len]
        (when (= @(Array.unsafe-nth &cs i) (Char.to-byte \+))
          (Array.aset! &cs i (Char.to-byte \ ))))
      (URI.unescape &(String.from-bytes &cs))))

  (defn decode [body]
    (let-do [result (the (Map String String) {})
             pairs &(String.split-by body &[\&])]
      (for [i 0 (Array.length pairs)]
        (let [pair (Array.unsafe-nth pairs i)]
          (when (> (String.length pair) 0)
            (let [eq (String.index-of pair \=)]
              (if (< eq 0)
                (Map.put! &result &(decode-form-value pair) &@"")
                (let [k (decode-form-value &(String.prefix pair eq))
                      v (decode-form-value &(String.suffix pair (+ eq 1)))]
                  (Map.put! &result &k &v)))))))
      result))

  (doc parse-request "parses the form body from a request. Returns an empty
map if the content type is not `application/x-www-form-urlencoded`.")
  (defn decode-request [req]
    (let [ct (Map.get-with-default (Request.headers req) "Content-Type"
               &[@""])]
      (if (String.starts-with? (Array.unsafe-first &ct) "application/x-www-form-urlencoded")
        (decode (Request.body req))
        (the (Map String String) {}))))
)

; ---------------------------------------------------------------------------
; WebSocket types
; ---------------------------------------------------------------------------

(doc WSEvent "represents an event on a WebSocket connection.

Handlers receive one of these for each lifecycle event:
- `Connect`: the connection was upgraded from HTTP
- `(Message msg)`: a text message arrived
- `Close`: the peer requested a close")
(deftype WSEvent
  Connect
  (Message [String])
  Close)

(doc WebSocket "represents an active WebSocket connection.

Handlers receive a reference to this and call [`WebSocket.send`](#send) to
queue outgoing text frames. The event loop drains the outbox after the handler
returns.")
(deftype WebSocket [fd Int
                    outbox (Array (Array Byte))])

(hidden WSFrame)
(deftype WSFrame [opcode Int payload (Array Byte) consumed Int])

(defmodule WebSocket
  (doc encode-text "encodes a string as a WebSocket text frame (no mask).")
  (defn encode-text [msg]
    (let-do [bytes (String.to-bytes msg)
             len (Array.length &bytes)
             frame (the (Array Byte) [])]
      (Array.push-back! &frame (Byte.from-int 129)) ; 0x81 FIN + text
      (cond
        (< len 126)
          (Array.push-back! &frame (Byte.from-int len))
        (< len 65536)
          (do (Array.push-back! &frame (Byte.from-int 126))
              (Array.push-back! &frame (Byte.from-int (/ len 256)))
              (Array.push-back! &frame (Byte.from-int (Int.mod len 256))))
        (do (Array.push-back! &frame (Byte.from-int 127))
            (for [k 0 4]
              (Array.push-back! &frame (Byte.from-int 0)))
            (Array.push-back! &frame (Byte.from-int (bit-and (bit-shift-right len 24) 255)))
            (Array.push-back! &frame (Byte.from-int (bit-and (bit-shift-right len 16) 255)))
            (Array.push-back! &frame (Byte.from-int (bit-and (bit-shift-right len 8) 255)))
            (Array.push-back! &frame (Byte.from-int (bit-and len 255)))))
      (for [k 0 len]
        (Array.push-back! &frame @(Array.unsafe-nth &bytes k)))
      frame))

  (hidden encode-pong)
  (defn encode-pong [payload]
    (let-do [len (Array.length payload)
             frame (the (Array Byte) [])]
      (Array.push-back! &frame (Byte.from-int 138)) ; 0x8A FIN + pong
      (Array.push-back! &frame (Byte.from-int len))
      (for [k 0 len]
        (Array.push-back! &frame @(Array.unsafe-nth payload k)))
      frame))

  (hidden encode-close)
  (defn encode-close []
    (the (Array Byte) [(Byte.from-int 136) (Byte.from-int 0)])) ; 0x88 FIN + close, len 0

  (hidden decode-frame)
  (defn decode-frame [buf offset]
    (let [len (Array.length buf)
          avail (- len offset)]
      (if (< avail 2)
        (the (Maybe WSFrame) (Maybe.Nothing))
        (let-do [b0 (Byte.to-int @(Array.unsafe-nth buf offset))
                 b1 (Byte.to-int @(Array.unsafe-nth buf (+ offset 1)))
                 opcode (bit-and b0 15)
                 masked (> (bit-and b1 128) 0)
                 plen0 (bit-and b1 127)
                 hdr-size 2
                 plen plen0
                 ok true]
          (cond
            (= plen0 126)
              (if (< avail 4)
                (set! ok false)
                (do (set! hdr-size 4)
                    (set! plen (+ (* (Byte.to-int @(Array.unsafe-nth buf (+ offset 2))) 256)
                                  (Byte.to-int @(Array.unsafe-nth buf (+ offset 3)))))))
            (= plen0 127)
              (if (< avail 10)
                (set! ok false)
                (do (set! hdr-size 10)
                    (set! plen (+ (+ (+ (* (Byte.to-int @(Array.unsafe-nth buf (+ offset 6))) 16777216)
                                        (* (Byte.to-int @(Array.unsafe-nth buf (+ offset 7))) 65536))
                                     (* (Byte.to-int @(Array.unsafe-nth buf (+ offset 8))) 256))
                                  (Byte.to-int @(Array.unsafe-nth buf (+ offset 9)))))))
            ())
          (if (not ok)
            (Maybe.Nothing)
            (let [mask-size (if masked 4 0)
                  total (+ (+ hdr-size mask-size) plen)]
              (if (< avail total)
                (Maybe.Nothing)
                (let-do [mask-off (+ offset hdr-size)
                         data-off (+ mask-off mask-size)
                         payload (Array.replicate plen &(Byte.from-int 0))]
                  (for [k 0 plen]
                    (let [b @(Array.unsafe-nth buf (+ data-off k))
                          unmasked (if masked
                                     (Byte.from-int (bit-xor (Byte.to-int b)
                                       (Byte.to-int @(Array.unsafe-nth buf (+ mask-off (Int.mod k 4))))))
                                     b)]
                      (Array.aset! &payload k unmasked)))
                  (Maybe.Just (WSFrame.init opcode payload total))))))))))

  (doc send "queues a text message for sending on the WebSocket connection.")
  (defn send [ws msg]
    (Array.push-back! (WebSocket.outbox ws) (encode-text msg)))

  (private ws-write-fd-)
  (hidden ws-write-fd-)
  (relative-include "src/ws_write.h")
  (register ws-write-fd- (Fn [Int &(Array Byte)] Int) "ws_write_fd")

  (doc send-now "sends a text message immediately, bypassing the outbox.
Writes the WebSocket frame directly to the socket. Use this inside handlers
that block for a long time (e.g. LLM streaming) so that each message reaches
the client without waiting for the handler to return.")
  (defn send-now [ws msg]
    (let [frame (encode-text msg)]
      (ignore (ws-write-fd- @(WebSocket.fd ws) &frame))))
)

; WebSocket accept key (RFC 6455 section 4.2.2)
(hidden ws-magic-guid)
(def ws-magic-guid @"258EAFA5-E914-47DA-95CA-C5AB0DC85B11")

(hidden ws-accept-key)
(defn ws-accept-key [client-key]
  (let [combined (String.append client-key &ws-magic-guid)
        hash (SHA1.digest &(String.to-bytes &combined))]
    (Base64.encode &hash)))

; ---------------------------------------------------------------------------
; Routing
; ---------------------------------------------------------------------------

(doc Handler "is the type of route handler functions.

A handler takes a reference to the parsed `Request` and a reference to a
`(Map String String)` of path parameters captured by `:name` segments in the
route pattern. It returns a `Response`.")

(deftype Route [method String,
                pattern String,
                handler (Fn [&Request &(Map String String)] Response)])

(doc match-route "matches a route `pattern` against a request `path`.

Pattern segments starting with `:` are named captures. A `*` as the last
segment matches the rest of the path and captures it as the `*` parameter.
The bare pattern `*` matches any path. Returns `(Maybe (Map String String))`
containing the captured parameters, or `Nothing` if the path does not match.

Examples: `/api/*` matches `/api/foo/bar` with `* = foo/bar`.
`/users/:id/*` matches `/users/42/posts/1` with `id = 42`, `* = posts/1`.")
(defn match-route [pattern path]
  (if (= pattern "*")
    (Maybe.Just (the (Map String String) {}))
    (let [pat-parts &(String.split-by pattern &[\/])
          path-parts &(String.split-by path &[\/])
          n-pat (Array.length pat-parts)
          n-path (Array.length path-parts)
          has-glob (and (> n-pat 0)
                        (= (Array.unsafe-nth pat-parts (- n-pat 1)) "*"))]
      (if (if has-glob
            (< n-path (- n-pat 1))
            (/= n-pat n-path))
        (Maybe.Nothing)
        (let-do [params (the (Map String String) {})
                 matched true
                 fixed-segs (if has-glob (- n-pat 1) n-pat)]
          (for [i 0 fixed-segs]
            (let [pp (Array.unsafe-nth pat-parts i)
                  rp (Array.unsafe-nth path-parts i)]
              (if (and (> (String.length pp) 0)
                       (= (String.char-at pp 0) \:))
                (let [k (String.suffix pp 1)]
                  (Map.put! &params &k rp))
                (when (/= pp rp)
                  (do (set! matched false) (break))))))
          ; Capture the glob tail if present
          (when (and matched has-glob)
            (let-do [tail @""]
              (for [j fixed-segs n-path]
                (do
                  (when (> j fixed-segs)
                    (set! tail (String.append &tail "/")))
                  (set! tail (String.append &tail (Array.unsafe-nth path-parts j)))))
              (Map.put! &params &@"*" &tail)))
          (if matched
            (Maybe.Just params)
            (Maybe.Nothing)))))))

(doc WSRoute "a WebSocket route entry. The handler receives a [`WSEvent`](#WSEvent),
the captured path parameters, and a [`WebSocket`](#WebSocket) handle for sending
responses.")
(deftype WSRoute [pattern String
                  handler (Fn [&WSEvent &(Map String String) &WebSocket] ())])

; ---------------------------------------------------------------------------
; App type (defined early so helpers can reference App.routes)
; ---------------------------------------------------------------------------

(deftype App [routes (Array Route)
              ws-routes (Array WSRoute)
              error-handler (Fn [&Request Int String] Response)])

; ---------------------------------------------------------------------------
; Internal helpers (top-level for reuse across serve modes)
; ---------------------------------------------------------------------------

(defn web-has-header-end [buf]
  (let-do [found false
           len (Array.length buf)]
    (when (>= len 4)
      (for [i 0 (- len 3)]
        (when (and (= @(Array.unsafe-nth buf i) (Char.to-byte \return))
                   (and (= @(Array.unsafe-nth buf (+ i 1)) (Char.to-byte \newline))
                        (and (= @(Array.unsafe-nth buf (+ i 2)) (Char.to-byte \return))
                             (= @(Array.unsafe-nth buf (+ i 3)) (Char.to-byte \newline)))))
          (do (set! found true) (break)))))
    found))

(defn web-keep-alive? [req]
  (let [http11 (= (Request.version req) "HTTP/1.1")
        default (if http11 @"keep-alive" @"close")
        conn (Map.get-with-default (Request.headers req) "Connection"
               &[default])]
    (not (= (Array.unsafe-first &conn) "close"))))

(defn web-finalize-response [resp keep-alive]
  (let [body-len (String.length (Response.body &resp))
        cl-k @"Content-Length"
        cl-v [(Int.str body-len)]
        conn-k @"Connection"
        conn-v [(if keep-alive @"keep-alive" @"close")]
        h (Map.put (Map.put @(Response.headers &resp) &cl-k &cl-v)
                   &conn-k &conn-v)]
    (Response.set-headers resp h)))

(defn read-request-buf [client buf]
  (let-do [got-request false]
    (TcpStream.clear-buf buf)
    (while true
      (match (TcpStream.read-append client buf)
        (Result.Error _) (break)
        (Result.Success n)
          (cond
            (<= n 0) (break)
            (web-has-header-end buf)
              (do (set! got-request true) (break))
            ())))
    got-request))

; Extract and URL-decode the request path. The leading "/" is stripped
; by `URI.path`, so this returns "" for the root.

(defn web-request-path [req]
  (URI.unescape
    &(match-ref (URI.path (Request.uri req))
       (Maybe.Just p) @p
       (Maybe.Nothing) @"")))

; Like web-request-path but with a leading "/" suitable for route matching.
(hidden web-routable-path)
(defn web-routable-path [req]
  (let [raw (web-request-path req)]
    (if (String.empty? &raw) @"/" (String.append "/" &raw))))

; Reject paths that contain ".." segments to prevent directory traversal.
(defn web-safe-path? [path]
  (let-do [parts &(String.split-by path &[\/])
           safe true]
    (for [i 0 (Array.length parts)]
      (when (= (Array.unsafe-nth parts i) "..")
        (do (set! safe false) (break))))
    safe))

(defn web-find-handler [routes req]
  (let-do [result (the (Maybe (Pair Int (Map String String))) (Maybe.Nothing))
           path (web-routable-path req)]
    (for [i 0 (Array.length routes)]
      (let [r (Array.unsafe-nth routes i)]
        (when (= (Route.method r) (Request.verb req))
          (match (match-route (Route.pattern r) &path)
            (Maybe.Just params)
              (do (set! result (Maybe.Just (Pair.init i params)))
                  (break))
            (Maybe.Nothing) ()))))
    result))

; Find a matching WebSocket route by path (method is always GET for upgrades).
(hidden web-find-ws-handler)
(defn web-find-ws-handler [ws-routes path]
  (let-do [result (the (Maybe (Pair Int (Map String String))) (Maybe.Nothing))]
    (for [i 0 (Array.length ws-routes)]
      (let [r (Array.unsafe-nth ws-routes i)]
        (match (match-route (WSRoute.pattern r) path)
          (Maybe.Just params)
            (do (set! result (Maybe.Just (Pair.init i params)))
                (break))
          (Maybe.Nothing) ())))
    result))

; Try to parse a WebSocket upgrade from a raw HTTP buffer. Returns
; (Maybe (Pair String (Pair Int (Map String String)))) — the accept key,
; route index, and params — or Nothing if it is not an upgrade.
(hidden web-try-ws-upgrade)
(defn web-try-ws-upgrade [buf ws-routes]
  (if (= 0 (Array.length ws-routes))
    (the (Maybe (Pair String (Pair Int (Map String String)))) (Maybe.Nothing))
    (let [raw &(String.from-bytes buf)]
      (match (Request.parse raw)
        (Result.Error _) (Maybe.Nothing)
        (Result.Success req)
          (let [has-upgrade
                  (let [vals (Map.get-with-default (Request.headers &req) "Upgrade"
                              &(the (Array String) []))]
                    (if (> (Array.length &vals) 0)
                      (= (Array.unsafe-first &vals) "websocket")
                      false))
                key-vals (Map.get-with-default (Request.headers &req) "Sec-WebSocket-Key"
                           &(the (Array String) []))]
            (if (and has-upgrade (> (Array.length &key-vals) 0))
              (let [path (web-routable-path &req)]
                (match (web-find-ws-handler ws-routes &path)
                  (Maybe.Just route-match)
                    (Maybe.Just (Pair.init (ws-accept-key (Array.unsafe-first &key-vals))
                                          @&route-match))
                  (Maybe.Nothing) (Maybe.Nothing)))
              (Maybe.Nothing)))))))

; Run before-hooks. Each hook can annotate `params` via Map.put! and
; optionally short-circuit by returning (Maybe.Just response).
(defn web-run-before [hooks req params]
  (let-do [result (the (Maybe Response) (Maybe.Nothing))]
    (for [i 0 (Array.length hooks)]
      (match (~(Array.unsafe-nth hooks i) req params)
        (Maybe.Just resp) (do (set! result (Maybe.Just resp)) (break))
        (Maybe.Nothing) ()))
    result))

; Run after-hooks, folding the response through each one.
(defn web-run-after [hooks req params resp]
  (let-do [r resp]
    (for [i 0 (Array.length hooks)]
      (set! r (~(Array.unsafe-nth hooks i) req params r)))
    r))

; Build the response for a complete request. Returns `(Pair Response Bool)`.
(defn web-build-response [app before-hooks after-hooks buf]
  (let [raw &(String.from-bytes buf)]
    (match (Request.parse raw)
      (Result.Error _)
        (Pair.init (Response.bad-request) false)
      (Result.Success req)
        (let [ka (web-keep-alive? &req)
              route-match (web-find-handler (App.routes app) &req)
              handler-idx (match-ref &route-match
                            (Maybe.Just p) @(Pair.a p)
                            (Maybe.Nothing) -1)
              params (match route-match
                       (Maybe.Just p) @(Pair.b &p)
                       (Maybe.Nothing) (the (Map String String) {}))
              resp (match (web-run-before before-hooks &req &params)
                     (Maybe.Just early) early
                     (Maybe.Nothing)
                       (if (< handler-idx 0)
                         (~(App.error-handler app) &req 404 @"Not Found")
                         (let [r (Array.unsafe-nth (App.routes app) handler-idx)]
                           (~(Route.handler r) &req &params))))
              final (web-run-after after-hooks &req &params resp)]
          (Pair.init final ka)))))

; Check if a response has an X-Sendfile header and extract the path.
(defn web-sendfile-path [resp]
  (match (Map.get-maybe (Response.headers resp) "X-Sendfile")
    (Maybe.Just vals)
      (if (> (Array.length &vals) 0)
        (Maybe.Just @(Array.unsafe-first &vals))
        (Maybe.Nothing))
    (Maybe.Nothing) (Maybe.Nothing)))

; Serialize a response for the wire. For sendfile responses, strips the
; X-Sendfile header and sets Content-Length from the file size.
(defn web-serialize-response [resp ka file-size]
  (let [clean (if (>= file-size 0l)
                (let [hdrs (Map.remove @(Response.headers &resp) &@"X-Sendfile")]
                  (-> resp (Response.set-body @"") (Response.set-headers hdrs)))
                resp)
        finalized (web-finalize-response clean ka)
        ; For sendfile: override Content-Length with the actual file size
        final (if (>= file-size 0l)
                (let [cl-key @"Content-Length"
                      cl-val [(Long.str file-size)]]
                  (Response.set-headers finalized
                    (Map.put @(Response.headers &finalized) &cl-key &cl-val)))
                finalized)
        s (Response.str &final)]
    (String.to-bytes &s)))

; ---------------------------------------------------------------------------
; App module
; ---------------------------------------------------------------------------

(deftype ConnState
  [streams         (Map Int TcpStream)
   read-bufs       (Map Int (Array Byte))
   write-bufs      (Map Int (Array Byte))
   write-positions (Map Int Int)
   keep-alives     (Map Int Bool)
   last-active     (Map Int Int)
   sf-fds          (Map Int Int)
   sf-offsets      (Map Int Long)
   sf-sizes        (Map Int Long)
   to-close        (Array Int)
   ws-route-idx    (Map Int Int)
   ws-params       (Map Int (Map String String))])

(defmodule App
  (doc create "creates an empty App with no routes and a default error handler.")
  (defn create []
    (init [] [] (fn [req code msg] (Response.with-status (Response.text @&msg) code msg))))

  (doc set-error "sets a custom error handler.")
  (defn set-error [app handler]
    (set-error-handler app handler))

  (doc route "adds a route to the app.")
  (defn route [app method pattern handler]
    (set-routes app
      (Array.push-back @(routes &app)
        (Route.init method pattern handler))))

  (doc GET "adds a GET route.")
  (defn GET [app pattern handler] (route app @"GET" pattern handler))
  (doc POST "adds a POST route.")
  (defn POST [app pattern handler] (route app @"POST" pattern handler))
  (doc PUT "adds a PUT route.")
  (defn PUT [app pattern handler] (route app @"PUT" pattern handler))
  (doc DELETE "adds a DELETE route.")
  (defn DELETE [app pattern handler] (route app @"DELETE" pattern handler))
  (doc PATCH "adds a PATCH route.")
  (defn PATCH [app pattern handler] (route app @"PATCH" pattern handler))

  (doc WS "adds a WebSocket route. The handler is called for each lifecycle
event ([`WSEvent`](#WSEvent)): `Connect`, `Message`, and `Close`.

```
(defn echo [event params ws]
  (match-ref event
    (WSEvent.Connect) (WebSocket.send ws @\"connected\")
    (WSEvent.Message msg) (WebSocket.send ws (fmt \"echo: %s\" msg))
    (WSEvent.Close) ()))

(defserver \"0.0.0.0\" 3000
  (WS \"/ws/echo\" echo))
```")
  (defn WS [app pattern handler]
    (set-ws-routes app
      (Array.push-back @(ws-routes &app)
        (WSRoute.init pattern handler))))

  (doc static-dir "registers a wildcard GET route that serves files from
`dir` on disk via sendfile. Register after API routes so it acts as a
fallback.")
  (defn static-dir [app dir]
    (route app @"GET" @"*"
      (fn [req params]
        (let [path (web-request-path req)
              rel (if (String.empty? &path) @"index.html" path)]
          (if (not (web-safe-path? &rel))
            (Response.not-found)
            (Response.sendfile &(String.append &(String.append &dir "/") &rel)))))))

  (def max-request-size 1048576)
  (def idle-timeout 60)
  (def running true)

  ; -----------------------------------------------------------------------
  ; Connection lifecycle helpers (take &ConnState, mutate in place)
  ; -----------------------------------------------------------------------

  (hidden queue-close)
  (defn queue-close [cs fd]
    (Array.push-back! (ConnState.to-close cs) fd))

  (hidden conn-done-writing)
  (defn conn-done-writing [cs poll fd]
    (let [ka (Map.get (ConnState.keep-alives cs) &fd)]
      (do
        (Map.remove! (ConnState.write-bufs cs) &fd)
        (Map.remove! (ConnState.write-positions cs) &fd)
        (Map.remove! (ConnState.keep-alives cs) &fd)
        (if ka
          (do (when (not (Map.contains? (ConnState.ws-route-idx cs) &fd))
                (Map.update-value! (ConnState.read-bufs cs) &fd
                  &(fn [b] (TcpStream.clear-buf b))))
              (ignore (Poll.modify poll fd poll-read)))
          (queue-close cs fd)))))

  (hidden conn-done-sendfile)
  (defn conn-done-sendfile [cs poll fd]
    (do
      (ignore (IO.Raw.close-fd (Map.get (ConnState.sf-fds cs) &fd)))
      (Map.remove! (ConnState.sf-fds cs) &fd)
      (Map.remove! (ConnState.sf-offsets cs) &fd)
      (Map.remove! (ConnState.sf-sizes cs) &fd)
      (conn-done-writing cs poll fd)))

  (hidden conn-cleanup)
  (defn conn-cleanup [cs poll fd]
    (do
      (ignore (Poll.remove-fd poll fd))
      (Map.update-value! (ConnState.streams cs) &fd &(fn [s] (TcpStream.close! s)))
      (Map.remove! (ConnState.streams cs) &fd)
      (Map.remove! (ConnState.read-bufs cs) &fd)
      (Map.remove! (ConnState.write-bufs cs) &fd)
      (Map.remove! (ConnState.write-positions cs) &fd)
      (Map.remove! (ConnState.keep-alives cs) &fd)
      (Map.remove! (ConnState.last-active cs) &fd)
      (when (Map.contains? (ConnState.sf-fds cs) &fd)
        (do (ignore (IO.Raw.close-fd (Map.get (ConnState.sf-fds cs) &fd)))
            (Map.remove! (ConnState.sf-fds cs) &fd)
            (Map.remove! (ConnState.sf-offsets cs) &fd)
            (Map.remove! (ConnState.sf-sizes cs) &fd)))
      (Map.remove! (ConnState.ws-route-idx cs) &fd)
      (Map.remove! (ConnState.ws-params cs) &fd)))

  ; -----------------------------------------------------------------------
  ; Event handlers
  ; -----------------------------------------------------------------------

  (hidden handle-accept)
  (defn handle-accept [cs poll listener]
    (match (TcpListener.accept listener)
      (Result.Error _) ()
      (Result.Success client)
        (let-do [cfd (TcpStream.poll-fd &client)]
          (TcpStream.set-nodelay &client)
          (TcpStream.set-nonblocking &client)
          (ignore (Poll.add poll cfd poll-read))
          (Map.put! (ConnState.streams cs) &cfd &client)
          (Map.put! (ConnState.read-bufs cs) &cfd &(the (Array Byte) []))
          (Map.put! (ConnState.last-active cs) &cfd &(System.time)))))

  (hidden handle-writable)
  (defn handle-writable [cs poll fd]
    (let [stream (Maybe.unsafe-from (Map.get-maybe (ConnState.streams cs) &fd))
          stream2 @&stream
          pos (Map.get (ConnState.write-positions cs) &fd)
          n (Map.value-ref! (ConnState.write-bufs cs) &fd
              &(fn [buf]
                (match (TcpStream.send-nb &stream buf pos)
                  (Result.Success k) k
                  (Result.Error _) -1))
              -1)]
      (cond
        (< n 0) (queue-close cs fd)
        (do
          (when (> n 0)
            (Map.put! (ConnState.last-active cs) &fd &(System.time)))
          (let [new-pos (+ pos n)
                buf-len (Map.value-ref! (ConnState.write-bufs cs) &fd
                          &(fn [b] (Array.length b)) 0)]
            (if (< new-pos buf-len)
              (Map.put! (ConnState.write-positions cs) &fd &new-pos)
              (if (Map.contains? (ConnState.sf-fds cs) &fd)
                (let-do [sf-fd (Map.get (ConnState.sf-fds cs) &fd)
                         sf-off (Map.get (ConnState.sf-offsets cs) &fd)
                         sf-sz (Map.get (ConnState.sf-sizes cs) &fd)
                         sn (match (TcpStream.sendfile-chunk &stream2 sf-fd &sf-off (- sf-sz sf-off))
                              (Result.Success k) k
                              (Result.Error _) -1)]
                  (Map.put! (ConnState.sf-offsets cs) &fd &sf-off)
                  (cond
                    (< sn 0)          (queue-close cs fd)
                    (>= sf-off sf-sz) (conn-done-sendfile cs poll fd)
                    ()))
                (conn-done-writing cs poll fd))))))))

  ; -----------------------------------------------------------------------
  ; WebSocket event handlers
  ; -----------------------------------------------------------------------

  (hidden ws-flatten-outbox)
  (defn ws-flatten-outbox [ws wbuf]
    (for [i 0 (Array.length (WebSocket.outbox ws))]
      (let [frame (Array.unsafe-nth (WebSocket.outbox ws) i)]
        (for [j 0 (Array.length frame)]
          (Array.push-back! wbuf @(Array.unsafe-nth frame j))))))

  (hidden handle-ws-upgrade)
  (defn handle-ws-upgrade [cs ws-routes poll fd stream accept route-idx params]
    (let-do [resp-str (fmt "HTTP/1.1 101 Switching Protocols\r\nUpgrade: websocket\r\nConnection: Upgrade\r\nSec-WebSocket-Accept: %s\r\n\r\n" accept)
             wbuf (String.to-bytes &resp-str)
             ws (WebSocket.init fd [])]
      (~(WSRoute.handler (Array.unsafe-nth ws-routes route-idx))
        &(WSEvent.Connect) params &ws)
      (ws-flatten-outbox &ws &wbuf)
      (Map.put! (ConnState.write-bufs cs) &fd &wbuf)
      (Map.put! (ConnState.write-positions cs) &fd &0)
      (Map.put! (ConnState.keep-alives cs) &fd &true)
      (Map.put! (ConnState.ws-route-idx cs) &fd &route-idx)
      (Map.put! (ConnState.ws-params cs) &fd params)
      (Map.update-value! (ConnState.read-bufs cs) &fd
        &(fn [b] (TcpStream.clear-buf b)))
      (let [n0 (Map.value-ref! (ConnState.write-bufs cs) &fd
                &(fn [b]
                  (match (TcpStream.send-nb &stream b 0)
                    (Result.Success k) k
                    (Result.Error _) -1))
                -1)
            buf-len (Array.length &wbuf)]
        (cond
          (< n0 0) (queue-close cs fd)
          (if (< n0 buf-len)
            (do (Map.put! (ConnState.write-positions cs) &fd &n0)
                (ignore (Poll.modify poll fd poll-write)))
            (conn-done-writing cs poll fd))))))

  (hidden handle-ws-readable)
  (defn handle-ws-readable [cs ws-routes poll fd]
    (let [stream (Maybe.unsafe-from (Map.get-maybe (ConnState.streams cs) &fd))
          stream2 @&stream
          n (Map.value-ref! (ConnState.read-bufs cs) &fd
              &(fn [buf]
                (match (TcpStream.read-append-nb &stream buf)
                  (Result.Success k) k
                  (Result.Error _) -1))
              -1)]
      (cond
        (= n TcpStream.read-blocked) ()
        (<= n 0) (queue-close cs fd)
        (do
          (Map.put! (ConnState.last-active cs) &fd &(System.time))
          (let-do [buf (Map.value-ref! (ConnState.read-bufs cs) &fd
                         &(fn [b] @b) (the (Array Byte) []))
                   route-idx (Map.get (ConnState.ws-route-idx cs) &fd)
                   params (Map.value-ref! (ConnState.ws-params cs) &fd
                            &(fn [p] @p) (the (Map String String) {}))
                   ws (WebSocket.init fd [])
                   offset 0
                   should-close false]
            (while (< offset (Array.length &buf))
              (match (WebSocket.decode-frame &buf offset)
                (Maybe.Nothing) (break)
                (Maybe.Just frame)
                  (let [op @(WSFrame.opcode &frame)
                        consumed @(WSFrame.consumed &frame)
                        plen (Array.length (WSFrame.payload &frame))]
                    (if (> plen App.max-request-size)
                      (do (set! should-close true) (break))
                      (do
                        (cond
                          (= op 1) ; text
                          (~(WSRoute.handler (Array.unsafe-nth ws-routes route-idx))
                            &(WSEvent.Message (String.from-bytes (WSFrame.payload &frame)))
                            &params &ws)
                        (= op 9) ; ping -> pong
                          (Array.push-back! (WebSocket.outbox &ws)
                            (WebSocket.encode-pong (WSFrame.payload &frame)))
                        (= op 8) ; close
                          (do (~(WSRoute.handler (Array.unsafe-nth ws-routes route-idx))
                                &(WSEvent.Close) &params &ws)
                              (Array.push-back! (WebSocket.outbox &ws)
                                (WebSocket.encode-close))
                              (set! should-close true))
                        ())
                        (set! offset (+ offset consumed)))))))
            ; Update read-buf with remaining bytes
            (if (>= offset (Array.length &buf))
              (Map.update-value! (ConnState.read-bufs cs) &fd
                &(fn [b] (TcpStream.clear-buf b)))
              (let-do [remaining (the (Array Byte) [])]
                (for [i offset (Array.length &buf)]
                  (Array.push-back! &remaining @(Array.unsafe-nth &buf i)))
                (Map.put! (ConnState.read-bufs cs) &fd &remaining)))
            ; Drain outbox
            (let [outbox-len (Array.length (WebSocket.outbox &ws))]
              (if (> outbox-len 0)
                (let-do [wbuf (the (Array Byte) [])]
                  (ws-flatten-outbox &ws &wbuf)
                  (Map.put! (ConnState.write-bufs cs) &fd &wbuf)
                  (Map.put! (ConnState.write-positions cs) &fd &0)
                  (Map.put! (ConnState.keep-alives cs) &fd &(not should-close))
                  (let [n0 (Map.value-ref! (ConnState.write-bufs cs) &fd
                            &(fn [b]
                              (match (TcpStream.send-nb &stream2 b 0)
                                (Result.Success k) k
                                (Result.Error _) -1))
                            -1)
                        buf-len (Array.length &wbuf)]
                    (cond
                      (< n0 0) (queue-close cs fd)
                      (if (< n0 buf-len)
                        (do (Map.put! (ConnState.write-positions cs) &fd &n0)
                            (ignore (Poll.modify poll fd poll-write)))
                        (if should-close
                          (queue-close cs fd)
                          ())))))
                (when should-close
                  (queue-close cs fd)))))))))

  (hidden handle-readable)
  (defn handle-readable [cs app before-hooks after-hooks poll fd]
    ; Active WebSocket connections bypass HTTP parsing
    (if (Map.contains? (ConnState.ws-route-idx cs) &fd)
      (handle-ws-readable cs (App.ws-routes app) poll fd)
      (let [stream (Maybe.unsafe-from (Map.get-maybe (ConnState.streams cs) &fd))
            stream2 @&stream
            n (Map.value-ref! (ConnState.read-bufs cs) &fd
                &(fn [buf]
                  (match (TcpStream.read-append-nb &stream buf)
                    (Result.Success k) k
                    (Result.Error _) -1))
                -1)]
        (cond
          (= n TcpStream.read-blocked) ()
          (<= n 0) (queue-close cs fd)
          (do
            (Map.put! (ConnState.last-active cs) &fd &(System.time))
            (let [too-big (Map.value-ref! (ConnState.read-bufs cs) &fd
                            &(fn [buf] (> (Array.length buf) App.max-request-size))
                            false)]
              (if too-big
                (queue-close cs fd)
                (let [ready (Map.value-ref! (ConnState.read-bufs cs) &fd
                              &(fn [buf] (web-has-header-end buf))
                              false)]
                  (when ready
                    ; Check for WebSocket upgrade before normal HTTP response
                    (let [ws-info (Map.value-ref! (ConnState.read-bufs cs) &fd
                                    &(fn [buf] (web-try-ws-upgrade buf (App.ws-routes app)))
                                    (the (Maybe (Pair String (Pair Int (Map String String)))) (Maybe.Nothing)))]
                      (if (Maybe.just? &ws-info)
                        (let [info (Maybe.unsafe-from ws-info)
                              accept @(Pair.a &info)
                              ri @(Pair.a (Pair.b &info))
                              ps @(Pair.b (Pair.b &info))]
                          (handle-ws-upgrade cs (App.ws-routes app) poll fd stream2 &accept ri &ps))
                        (let [pair (Map.value-ref! (ConnState.read-bufs cs) &fd
                                     &(fn [buf] (web-build-response app before-hooks after-hooks buf))
                                     (Pair.init (Response.bad-request) false))
                              resp @(Pair.a &pair)
                              ka @(Pair.b &pair)
                              sf-path (web-sendfile-path &resp)
                              sf-result (match-ref &sf-path
                                          (Maybe.Just p)
                                            (let [ffd (IO.Raw.open p IO.Raw.O-RDONLY)]
                                              (if (< ffd 0)
                                                -1l
                                                (let [sz (IO.Raw.fstat-size ffd)]
                                                  (do (Map.put! (ConnState.sf-fds cs) &fd &ffd)
                                                      (Map.put! (ConnState.sf-offsets cs) &fd &0l)
                                                      (Map.put! (ConnState.sf-sizes cs) &fd &sz)
                                                      sz))))
                                          (Maybe.Nothing) -1l)
                              actual-resp (if (and (Maybe.just? &sf-path) (< sf-result 0l))
                                            (Response.not-found) resp)
                              wbuf (web-serialize-response actual-resp ka sf-result)]
                          (do
                            (Map.put! (ConnState.write-bufs cs) &fd &wbuf)
                            (Map.put! (ConnState.write-positions cs) &fd &0)
                            (Map.put! (ConnState.keep-alives cs) &fd &ka)
                            (let [n0 (Map.value-ref! (ConnState.write-bufs cs) &fd
                                      &(fn [b]
                                        (match (TcpStream.send-nb &stream2 b 0)
                                          (Result.Success k) k
                                          (Result.Error _) -1))
                                      -1)
                                  buf-len (Array.length &wbuf)]
                              (cond
                                (< n0 0) (queue-close cs fd)
                                (if (or (< n0 buf-len) (Map.contains? (ConnState.sf-fds cs) &fd))
                                  (do (Map.put! (ConnState.write-positions cs) &fd &n0)
                                      (ignore (Poll.modify poll fd poll-write)))
                                  (conn-done-writing cs poll fd)))))))))))))))))

  (hidden sweep-idle)
  (defn sweep-idle [cs]
    (let [now (System.time)
          keys (Map.keys (ConnState.last-active cs))]
      (for [j 0 (Array.length &keys)]
        (let [rfd @(Array.unsafe-nth &keys j)
              ts (Map.get (ConnState.last-active cs) &rfd)]
          (when (> (- now ts) App.idle-timeout)
            (queue-close cs rfd))))))

  (hidden flush-closed)
  (defn flush-closed [cs poll]
    (for [j 0 (Array.length (ConnState.to-close cs))]
      (conn-cleanup cs poll @(Array.unsafe-nth (ConnState.to-close cs) j))))

  ; -----------------------------------------------------------------------
  ; Macro helpers for defserver
  ; -----------------------------------------------------------------------

  (hidden static-form?)
  (defndynamic static-form? [f]
    (and (list? f) (= 'static (car f))))

  (hidden before-form?)
  (defndynamic before-form? [f]
    (and (list? f) (= 'before (car f))))

  (hidden after-form?)
  (defndynamic after-form? [f]
    (and (list? f) (= 'after (car f))))

  (hidden errors-form?)
  (defndynamic errors-form? [f]
    (and (list? f) (= 'errors (car f))))

  (hidden route-form?)
  (defndynamic route-form? [f]
    (and (list? f)
         (or (= 'GET (car f)) (= 'POST (car f)) (= 'PUT (car f))
             (= 'DELETE (car f)) (= 'PATCH (car f)) (= 'WS (car f))
             (= 'static (car f)) (= 'before (car f)) (= 'after (car f))
             (= 'errors (car f)))))

  (hidden route-call)
  (defndynamic route-call [r]
    (cond
      (App.static-form? r)  (list 'App.static-dir (list 'copy (cadr r)))
      (App.before-form? r)  (list 'App.use-before (cadr r))
      (App.after-form? r)   (list 'App.use-after (cadr r))
      (App.errors-form? r)  (list 'App.set-error (cadr r))
      (list (Symbol.prefix 'App (car r))
            (list 'copy (cadr r))
            (caddr r))))

  ; -----------------------------------------------------------------------
  ; serve
  ; -----------------------------------------------------------------------

  (doc serve "starts the web server on `host`:`port`.

Uses kqueue/epoll for concurrent connection handling with HTTP keep-alive.
Sockets are non-blocking, reads accumulate into a per-connection buffer,
and writes drain across writable events.

The loop is single-threaded, so peak throughput is bounded by one core.
For multi-core scaling, run several copies behind a TCP load balancer.")
  (defn serve [app before-hooks after-hooks host port]
    (match (TcpListener.bind host port)
      (Result.Error e)
        (IO.errorln &(fmt "Failed to bind: %s" &e))
      (Result.Success listener)
        (match (Poll.create)
          (Result.Error e)
            (do (IO.errorln &e) (TcpListener.close listener))
          (Result.Success poll)
            (let-do [lfd (TcpListener.poll-fd &listener)
                     cs (ConnState.init {} {} {} {} {} {} {} {} {} [] {} {})]
              (IO.println &(fmt "Listening on %s:%d" host port))
              (set! App.running true)
              (System.signal System.signal-int  (fn [_] (set! App.running false)))
              (System.signal System.signal-term (fn [_] (set! App.running false)))
              (ignore (Poll.add-read &poll &listener))
              (while App.running
                (match (the (Result (Array PollEvent) String) (Poll.wait &poll 30000))
                  (Result.Error _) (break)
                  (Result.Success events)
                    (do
                      (ConnState.set-to-close! &cs [])
                      (for [i 0 (Array.length &events)]
                        (let [e (Array.unsafe-nth &events i)
                              fd (PollEvent.fd e)]
                          (cond
                            (= fd lfd)             (handle-accept &cs &poll &listener)
                            (PollEvent.writable e)  (handle-writable &cs &poll fd)
                            (PollEvent.readable e)  (handle-readable &cs app before-hooks after-hooks &poll fd)
                            ())))
                      (sweep-idle &cs)
                      (flush-closed &cs &poll))))
              (Poll.close poll)
              (TcpListener.close listener)))))
)
 ; end defmodule App

; ---------------------------------------------------------------------------
; Built-in middleware: CORS
; ---------------------------------------------------------------------------

(defmodule CORS
  (def origin @"*")
  (def methods @"GET, POST, PUT, DELETE, PATCH, OPTIONS")
  (def headers @"Content-Type, Authorization")
  (def max-age @"86400")

  (doc configure "sets the allowed origin for CORS. Call before the server
starts. The default is `*` (all origins).")
  (defn configure [allowed-origin]
    (set! origin allowed-origin))

  (doc before-hook "handles CORS preflight `OPTIONS` requests. Returns a
`204 No Content` with the appropriate `Access-Control-*` headers. For
non-OPTIONS requests, continues to the handler.")
  (defn before-hook [req params]
    (if (= (Request.verb req) "OPTIONS")
      ; Allow-Origin is added by after-hook; only set the other CORS headers here
      (Maybe.Just (-> (Response.text @"")
                      (Response.with-status 204 @"No Content")
                      (Response.with-header @"Access-Control-Allow-Methods" @&methods)
                      (Response.with-header @"Access-Control-Allow-Headers" @&headers)
                      (Response.with-header @"Access-Control-Max-Age" @&max-age)))
      (Maybe.Nothing)))

  (doc after-hook "adds `Access-Control-Allow-Origin` to every response.")
  (defn after-hook [req params resp]
    (Response.with-header resp @"Access-Control-Allow-Origin" @&origin))
)

; ---------------------------------------------------------------------------
; Cookie response helper
; ---------------------------------------------------------------------------

(defmodule Response
  (doc set-cookie "adds a `Set-Cookie` header to the response. The `cookie`
argument is a `Cookie` value from the `http` library.

```
(Response.set-cookie resp
  (Cookie.init @\"session\" @\"abc\" @\"/\"
    (Maybe.Nothing) (Maybe.Nothing) true true (SameSite.Lax)))
```

For simple name/value cookies, use [`set-simple-cookie`](#set-simple-cookie).")
  (defn set-cookie [resp cookie]
    (with-header resp @"Set-Cookie" (Cookie.set &cookie)))

  (doc set-simple-cookie "adds a `Set-Cookie` header with a name and value.
Uses `Path=/`, `HttpOnly`, and `SameSite=Lax` as defaults.")
  (defn set-simple-cookie [resp name value]
    (set-cookie resp
      (Cookie.init name value @"/"
        (Maybe.Nothing) (Maybe.Nothing) false true (SameSite.Lax))))
)

; ---------------------------------------------------------------------------
; Built-in middleware: request logging
; ---------------------------------------------------------------------------

(doc log-before "before-hook that records the request start time in params
under the key `_start`. Pair with [`log-after`](#log-after).")
(defn log-before [req params]
  (do (Map.put! params &@"_start" &(Long.str (Uint64.to-long (System.nanotime))))
      (Maybe.Nothing)))

(doc log-after "after-hook that prints `METHOD path STATUS TIMEms` to
stdout. Reads the start time from `_start` in params, set by
[`log-before`](#log-before).

```
(defserver \"0.0.0.0\" 3000
  (before log-before)
  (after log-after)
  (GET \"/\" hello))
```")
(defn log-after [req params resp]
  (let [start (Maybe.unsafe-from (Long.from-string &(Map.get params "_start")))
        now (Uint64.to-long (System.nanotime))
        elapsed (/ (- now start) 1000000l)]
    (do (Log.info "%s /%s %d %ldms"
          (Request.verb req)
          &(web-request-path req)
          (Response.code &resp)
          elapsed)
        resp)))

; ---------------------------------------------------------------------------
; defserver: generate a main that builds an App and starts serving
; ---------------------------------------------------------------------------

(doc defserver "generates a `main` function that builds an `App`, registers
routes, and starts serving on `host`:`port`.

Each route is `(METHOD \"/path\" handler)` where METHOD is one of `GET`,
`POST`, `PUT`, `DELETE`, or `PATCH`. Any other form in the body is
evaluated as a setup expression before the server starts, in source order.

```
(defserver \"0.0.0.0\" 3000
  (Item.create-table &db)
  (GET    \"/api/todos\"     api-list)
  (POST   \"/api/todos\"     api-add)
  (DELETE \"/api/todos/:id\" api-delete))
```

is equivalent to:

```
(defn main []
  (let [app (-> (App.create) (App.GET @\"/\" hello))
        bh (the (Array (Fn [&Request] (Maybe Response))) [])
        ah (the (Array (Fn [&Request Response] Response)) [])]
    (App.serve &app &bh &ah \"0.0.0.0\" 3000)))
```")
(defmacro defserver [host port :rest body]
  (let [; Separate routes, hooks, and setup expressions
        routes (filter (fn [f] (and (App.route-form? f)
                                    (not (App.before-form? f))
                                    (not (App.after-form? f)))) body)
        befores (filter App.before-form? body)
        afters (filter App.after-form? body)
        setup (filter (fn [f] (not (App.route-form? f))) body)
        ; Build the app with routes
        app-form (cons '-> (cons '(App.create) (map App.route-call routes)))
        ; Build hook arrays as lambdas wrapping the user's functions
        before-arr (collect-into
                     (map (fn [f] (list 'fn ['req 'params] (list (cadr f) 'req 'params)))
                          befores)
                     array)
        after-arr (collect-into
                    (map (fn [f] (list 'fn ['req 'params 'resp] (list (cadr f) 'req 'params 'resp)))
                         afters)
                    array)
        body-forms (append setup
                    (list (list 'let ['app app-form
                                      'bh before-arr
                                      'ah after-arr]
                            (list 'App.serve '&app '&bh '&ah host port))))]
    (eval (list 'defn 'main (array)
      (cons 'do body-forms)))))
